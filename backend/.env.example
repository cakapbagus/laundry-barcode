# JWT secret — gunakan string acak panjang (min 32 karakter) di production
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter

# Port server backend
PORT=3001

# Database — SQLite (default untuk dev & VPS)
DATABASE_URL=file:./dev.db

# URL frontend untuk QR code order tracking — WAJIB diubah di VPS production
# Dev: http://localhost:5173
# VPS: https://laundry.yourdomain.com
FRONTEND_URL=http://localhost:5173

# CORS: daftar origin frontend yang diizinkan, pisahkan dengan koma
# Development:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# VPS production (ganti dengan domain/IP VPS kamu):
# ALLOWED_ORIGINS=https://laundry.yourdomain.com
